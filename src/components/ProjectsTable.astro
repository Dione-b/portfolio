---
interface ProjectRow {
  name: string;
  stack: string;
  highlight: string;
  highlightColor: string;
  url: string;
}

const projects: ProjectRow[] = [
  { name: "Caatinga", stack: "TypeScript · Soroban", highlight: "DX Blockchain", highlightColor: "text-green-accent", url: "https://github.com/Dione-b/caatinga" },
  { name: "Prumo", stack: "Python · Playwright", highlight: "AI · CLI", highlightColor: "text-accent", url: "https://github.com/Dione-b/prumo" },
  { name: "Horus", stack: "Go · OSINT · React", highlight: "OSINT / Investigation", highlightColor: "text-yellow-400", url: "https://github.com/Dione-b/horus" },
  { name: "Notus API Intelligence", stack: "TypeScript · Express", highlight: "AI · APIs", highlightColor: "text-accent", url: "https://github.com/Dione-b/notus-api-debug" },
  { name: "Acesso Cidadão", stack: "Next.js · Strapi", highlight: "Citizen Portal", highlightColor: "text-green-accent", url: "https://github.com/Dione-b/acesso-cidadao" },
];
---

<section id="all-projects" class="scroll-mt-16 py-12 px-5 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl font-bold mb-6 font-mono">All Projects</h2>

    <div class="grid gap-3 sm:hidden">
      {
        projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener"
            class="block border border-border rounded-lg p-4 bg-surface hover:bg-surface-hover hover:border-accent/50 transition-all"
          >
            <div class="flex items-center justify-between gap-3">
              <span class="font-medium">{project.name}</span>
              <span class="text-accent shrink-0">→</span>
            </div>
            <p class="font-mono text-xs text-ink-muted mt-1">{project.stack}</p>
            <span class={`inline-block mt-2 text-xs font-mono ${project.highlightColor}`}>{project.highlight}</span>
          </a>
        ))
      }
    </div>

    <div class="hidden sm:block">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border text-ink-muted font-mono">
            <th class="text-left py-3 px-4">Project</th>
            <th class="text-left py-3 px-4">Stack</th>
            <th class="text-left py-3 px-4">Highlight</th>
            <th class="text-left py-3 px-4">Link</th>
          </tr>
        </thead>
        <tbody>
          {
            projects.map((project, index) => (
              <tr class={`hover:bg-surface-hover transition-colors ${index < projects.length - 1 ? "border-b border-border/50" : ""}`}>
                <td class="py-3 px-4 font-medium">{project.name}</td>
                <td class="py-3 px-4 font-mono text-ink-muted">{project.stack}</td>
                <td class="py-3 px-4"><span class={project.highlightColor}>{project.highlight}</span></td>
                <td class="py-3 px-4"><a href={project.url} target="_blank" rel="noopener" class="text-accent hover:underline">→</a></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
