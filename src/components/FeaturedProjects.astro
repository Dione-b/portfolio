---
interface Project {
  name: string;
  tagline: string;
  highlights: string[];
  stack: string[];
  sections: { heading: string; content: string }[];
  links: { label: string; url: string }[];
}

const projects: Project[] = [
  {
    name: "Caatinga",
    tagline: "Deployment orchestration and versioned artifacts toolkit for Soroban smart contracts. 4 packages published on npm.",
    highlights: [
      "TypeScript monorepo with 4 packages: cli, core, client, zk",
      "CLI with 25+ commands (init, build, deploy, invoke, doctor, zk)",
      "Graph-aware deploy with inter-contract dependencies",
      "Automatic TypeScript bindings generation",
      "Client SDK with Freighter + Stellar Wallets Kit adapters",
      "ZK pipeline with Circom + Groth16 for on-chain verification",
      "6 documented Architecture Decision Records",
      "Documentation for humans and coding agents (llms.txt)",
    ],
    stack: ["TypeScript", "Stellar", "Soroban", "CLI"],
    sections: [
      {
        heading: "Overview",
        content:
          "Caatinga is an open-source ecosystem for Stellar network development, focused on deploy orchestration, artifact versioning, and TypeScript bindings generation for Soroban contracts — without requiring a centralized registry.",
      },
      {
        heading: "Architecture",
        content:
          "pnpm monorepo with 4 packages: @caatinga/cli (Commander, 25+ commands), @caatinga/core (orchestration with Zod + execa), @caatinga/client (browser SDK with wallet adapters + React hooks), @caatinga/zk (Groth16 serialization for Circom). Core never imports CLI; Client only imports the browser subpath from Core.",
      },
      {
        heading: "Differentiator",
        content:
          "Git-versioned artifacts as the source of truth (no registry). Deploy with topological ordering of inter-contract dependencies. Integrated CI/CD pipeline. Stable CAATINGA_* error codes as a public API for automation.",
      },
    ],
    links: [
      { label: "GitHub", url: "https://github.com/Dione-b/caatinga" },
      { label: "Docs", url: "https://dione-b.github.io/caatinga/" },
      { label: "npm (@caatinga/cli)", url: "https://www.npmjs.com/package/@caatinga/cli" },
    ],
  },
  {
    name: "Prumo",
    tagline: "CLI that converts documentation and GitHub repositories into llms.md files, creating structured context for AI agents.",
    highlights: [
      "Crawler for static HTML and JS-rendered pages",
      "GitHub API integration",
      "LLM-optimized export",
      "Reduced hallucinations in AI agents",
    ],
    stack: ["Python", "CLI", "Playwright", "AI"],
    sections: [
      {
        heading: "Problem",
        content:
          "AI agents struggle with outdated or poorly structured context. Technical documentation scattered across multiple sources hurts answer accuracy.",
      },
      {
        heading: "Solution",
        content:
          "CLI that crawls any documentation (static or dynamic) and generates an llms.md file optimized for LLMs, reducing hallucinations and improving generated code quality.",
      },
      {
        heading: "Architecture",
        content:
          "Python core with Playwright for JS rendering. Two crawl modes: shallow (static HTML, fast) and deep (with JS, captures SPAs). Post-processing pipeline that cleans, structures, and optimizes output for the llms.md format.",
      },
    ],
    links: [{ label: "GitHub", url: "https://github.com/Dione-b/prumo" }],
  },
  {
    name: "Horus",
    tagline: "Forensic OSINT identity correlation platform. 12+ IOC types, modular pipeline with 6 search modules, rule-based correlation, and relational graph.",
    highlights: [
      "12+ indicators: username, email, phone, domain, wallet, metadata",
      "6 search modules (username, email, phone, domain, wallet, metadata)",
      "12 correlation rules with confidence scoring",
      "Interactive relational graph with vis-network",
      "Chain of custody with SHA-256 hash per evidence",
      "React 19 web dashboard embedded in Go binary",
      "AI analysis (LLM or heuristic)",
      "11 CLI commands (search, resolve, correlate, report, analyze, dashboard, graph...)",
    ],
    stack: ["Go", "OSINT", "Modular", "React"],
    sections: [
      {
        heading: "Overview",
        content:
          "Forensic OSINT identity correlation platform. Searches and correlates multiple indicators (username, email, phone, domain, wallet, documents) to build unified profiles with verifiable chain of custody.",
      },
      {
        heading: "Architecture",
        content:
          "8-stage Go pipeline: Search (concurrent modules with goroutines + semaphore) → Enrichment (GitHub, Keybase, PGP, Maigret) → Correlation (12 rules with scoring) → Timeline → Graph → AI → Screenshots → Evidence (hash + dedup + validation). Graph traversal with BFS for username-to-contact resolution.",
      },
      {
        heading: "Differentiator",
        content:
          "12 correlation rules (Username-Email, Avatar-Username, Document-Author, etc.) with calculated confidence. Evidence with SHA-256 hash for forensic integrity. React dashboard embedded via //go:embed. Cobra CLI with 11 commands. SQLite for case persistence.",
      },
    ],
    links: [{ label: "GitHub", url: "https://github.com/Dione-b/horus" }],
  },
  {
    name: "Notus API Intelligence",
    tagline: "Platform for API testing, analysis, and debugging with automatic insight generation using LLMs.",
    highlights: [
      "23 endpoints across multiple categories",
      "P50, P95, and P99 metrics",
      "Health Score and error analysis",
      "Google Gemini integration",
      "Automatic sensitive data sanitization",
    ],
    stack: ["TypeScript", "Express", "React", "AI"],
    sections: [
      {
        heading: "Problem",
        content:
          "Developers spend hours manually debugging APIs — testing endpoints, analyzing responses, identifying failure patterns. A repetitive process prone to human error.",
      },
      {
        heading: "Solution",
        content:
          "Platform that automates API testing, collects performance metrics (P50, P95, P99), calculates Health Score, and generates LLM-powered insights to diagnose issues.",
      },
      {
        heading: "Architecture",
        content:
          "Express backend with 23 categorized endpoints. Automated testing system with metrics collection. Google Gemini integration for semantic error analysis. Automatic sanitization pipeline to remove sensitive data before sending to the LLM.",
      },
    ],
    links: [{ label: "GitHub", url: "https://github.com/Dione-b/notus-api-debug" }],
  },
  {
    name: "Acesso Cidadão",
    tagline: "Citizen portal connecting people to social programs with client-side eligibility logic — no personal data collection.",
    highlights: [
      "Client-side matching",
      "Privacy-first design",
      "Public data organization",
      "Next.js + Strapi architecture",
    ],
    stack: ["Next.js", "Open Source", "Privacy", "Public Data"],
    sections: [
      {
        heading: "Problem",
        content:
          "Low-income citizens are unaware of social programs they qualify for. Government platforms are fragmented and hard to navigate.",
      },
      {
        heading: "Solution",
        content:
          "Platform that centralizes social programs and enables eligibility matching without storing personal data — all logic runs on the user's frontend.",
      },
      {
        heading: "Architecture",
        content:
          "Next.js frontend with client-side matching logic. Strapi as CMS for public data. Zero personal data collection — privacy as an architectural principle, not a feature.",
      },
    ],
    links: [{ label: "GitHub", url: "https://github.com/Dione-b/acesso-cidadao" }],
  },
];
---

<section id="projects" class="scroll-mt-16 py-12 px-5 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold mb-2 font-mono">Featured Projects</h2>
    <p class="text-ink-muted mb-12 max-w-lg">Infrastructure, architecture decisions, and production-grade backend systems.</p>

    <div class="space-y-20">
      {
        projects.map((project) => (
          <article class="border border-border rounded-lg p-6 sm:p-8 bg-surface">
            <div class="mb-6">
              <h3 class="text-2xl font-bold">{project.name}</h3>
              <p class="text-ink-muted mt-1">{project.tagline}</p>
            </div>

            {
              project.name === "Caatinga" && (
                <div class="overflow-x-auto mb-6">
                  <img
                    src="/assets/caatinga-status-cli.png"
                    alt="Caatinga CLI — caatinga status on stellar-album"
                    class="w-full max-w-3xl mx-auto rounded-lg border border-border object-contain"
                  />
                </div>
              )
            }

            <div class="flex flex-wrap gap-2 mb-6">
              {project.stack.map((tech) => (
                <span class="px-2 py-1 text-xs font-mono bg-background text-ink-muted rounded border border-border">
                  {tech}
                </span>
              ))}
            </div>

            <details class="group mb-4">
              <summary class="text-sm font-semibold text-accent font-mono cursor-pointer hover:text-ink transition-colors list-none flex items-center gap-2">
                <span>Highlights</span>
                <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </summary>
              <ul class="mt-3 space-y-1.5">
                {project.highlights.map((h) => (
                  <li class="text-sm text-ink-muted flex items-start gap-2">
                    <span class="text-accent mt-0.5">▹</span>
                    {h}
                  </li>
                ))}
              </ul>
            </details>

            <div class="space-y-4">
              {project.sections.map((section) => (
                <div>
                  <h4 class="text-sm font-semibold text-accent font-mono mb-1">{section.heading}</h4>
                  <p class="text-ink-muted text-sm leading-relaxed">{section.content}</p>
                </div>
              ))}
            </div>

            <div class="flex flex-wrap gap-4 mt-6 pt-4 border-t border-border">
              {project.links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener" class="text-sm text-accent hover:text-ink transition-colors font-mono">
                  {link.label} →
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
