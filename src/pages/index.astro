---
import Layout from "../layouts/Layout.astro";
import HorizontalScroll from "../components/HorizontalScroll.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import ProjectsTable from "../components/ProjectsTable.astro";
import Articles from "../components/Articles.astro";
import Skills from "../components/Skills.astro";
import Timeline from "../components/Timeline.astro";
import Contact from "../components/Contact.astro";
---

<Layout>
  <HorizontalScroll labels={["Início", "Stats", "Projetos", "Tabela", "Artigos", "Skills", "Timeline", "Contato"]}>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <Hero />
    </div>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <Stats />
    </div>
    <div class="w-screen h-screen flex-shrink-0 overflow-y-auto" data-scrollable>
      <FeaturedProjects />
    </div>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <ProjectsTable />
    </div>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <Articles />
    </div>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <Skills />
    </div>
    <div class="w-screen h-screen flex-shrink-0 overflow-y-auto" data-scrollable>
      <Timeline />
    </div>
    <div class="w-screen h-screen flex-shrink-0 flex items-center justify-center">
      <Contact />
    </div>
  </HorizontalScroll>
</Layout>
